# General
ENVIRONMENT=production

# API
PROJECT_NAME=Mande24 Independent API
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://mande24_user:change_me_strong@postgres:5432/mande24
AUTO_CREATE_TABLES=false
JWT_SECRET_KEY=replace_with_a_very_long_random_secret_value_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENFORCE_SECURITY_IN_LOCAL=true
CORS_ALLOW_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
CORS_ALLOW_CREDENTIALS=true
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_REGISTER_RATE_LIMIT=10
AUTH_LOGIN_RATE_LIMIT=15
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_CONTACT_RATE_LIMIT=10
PUBLIC_QUOTE_RATE_LIMIT=30
PUBLIC_TRACKING_RATE_LIMIT=60
NATIONAL_SAME_STATE_FACTOR=1.0
NATIONAL_CROSS_STATE_FACTOR=1.1
NATIONAL_CROSS_REGION_FACTOR=1.12
NATIONAL_CROSS_ZONE_FACTOR=1.06
NATIONAL_STATION_HANDOFF_FACTOR=1.04
ENABLE_COMMISSION_SCHEDULER=true
COMMISSION_CLOSE_HOUR_UTC=1
COMMISSION_CLOSE_MINUTE_UTC=0
COMMISSION_SCHEDULER_RUN_ON_STARTUP=false

# Web
NEXT_PUBLIC_API_URL=https://api.tu-dominio.com

# Postgres
POSTGRES_DB=mande24
POSTGRES_USER=mande24_user
POSTGRES_PASSWORD=change_me_strong
