[Unit]
Description=Mande24 Weekly Commission Close
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/mande24/mande24_independent/apps/api
EnvironmentFile=/opt/mande24/mande24_independent/.env
ExecStart=/usr/bin/python3 -m app.scripts.close_commissions
User=mande24
Group=mande24

[Install]
WantedBy=multi-user.target
